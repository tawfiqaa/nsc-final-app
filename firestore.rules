rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      // Fetch the requesting user's document to check their role
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    
    // Check if the requester is an Admin or Super Admin
    function isAdmin() {
      let userData = getUserData();
      return userData.role == 'admin' || userData.role == 'super_admin';
    }
    
    function isSuperAdmin() {
      let userData = getUserData();
      return userData.role == 'super_admin';
    }

    // Users collection
    match /users/{uid} {
      // Read: Authenticated users can read (needed for admin list), 
      // strictly speaking teachers only need to read their own, but Admins need all.
      allow read: if isAuthenticated();
      
      // Creation: allow if auth uid matches the doc uid
      allow create: if isAuthenticated() && isOwner(uid);
      
      // Update:
      allow update: if isAuthenticated() && isSuperAdmin();

      // Subcollections for V2 schema
      match /schedules/{scheduleId} {
        allow read: if isAuthenticated() && (isOwner(uid) || isAdmin());
        allow write: if isAuthenticated() && isOwner(uid);
      }
      
      match /lessons/{lessonId} {
        allow read: if isAuthenticated() && (isOwner(uid) || isAdmin());
        allow write: if isAuthenticated() && isOwner(uid);
      }
      
      match /schools/{schoolId} {
        allow read: if isAuthenticated() && (isOwner(uid) || isAdmin());
        allow write: if isAuthenticated() && isOwner(uid);
      }
    }

    // TeacherData collection
    match /teacherData/{teacherUid} {
      // Read: Owner or Admin
      allow read: if isAuthenticated() && (isOwner(teacherUid) || isAdmin());
      
      // Write: Owner only (Admins are read-only for teacherData content)
      allow write: if isAuthenticated() && isOwner(teacherUid);
    }
  }
}
