rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ─────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isSuperAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
    }

    // Org membership helpers
    function getOrgMember(orgId) {
      return get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data;
    }

    function isApprovedOrgMember(orgId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)) &&
        getOrgMember(orgId).status == 'approved';
    }

    function isOrgAdminOrOwner(orgId) {
      return isApprovedOrgMember(orgId) &&
        (getOrgMember(orgId).role == 'admin' || getOrgMember(orgId).role == 'owner');
    }


    // ── USERS ───────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth() && (
        isOwner(uid) || 
        isSuperAdmin() || 
        isOrgAdminOrOwner(resource.data.activeOrgId)
      );
      allow create, update: if isAuth() && (isOwner(uid) || isSuperAdmin());
      allow delete: if false;

      // User's org membership index (read by owner, written by org admin actions too)
      match /orgMemberships/{orgId} {
        allow read: if isAuth() && isOwner(uid);
        allow write: if isAuth() && (isOwner(uid) || isSuperAdmin() || isOrgAdminOrOwner(orgId));
      }

      // Legacy V2 user-scoped subcollections (kept for backward compat)
      match /schedules/{scheduleId} {
        allow read, write: if isAuth() && (isOwner(uid) || isSuperAdmin());
      }
      match /lessons/{lessonId} {
        allow read, write: if isAuth() && (isOwner(uid) || isSuperAdmin());
        match /attendance/{studentId} {
          allow read, write: if isAuth() && (isOwner(uid) || isSuperAdmin());
        }
      }
      match /schools/{schoolId} {
        allow read, write: if isAuth() && (isOwner(uid) || isSuperAdmin());
        match /students/{studentId} {
          allow read, write: if isAuth() && (isOwner(uid) || isSuperAdmin());
        }
      }
      match /settings/{settingId} {
        allow read: if isAuth() && (
          isOwner(uid) || 
          isSuperAdmin() || 
          isOrgAdminOrOwner(get(/databases/$(database)/documents/users/$(uid)).data.activeOrgId)
        );
        allow write: if isAuth() && (isOwner(uid) || isSuperAdmin());
      }
    }

    // ── ORGANIZATIONS ───────────────────────────────────────
    match /orgs/{orgId} {
      // Any authenticated user can read (needed to validate join codes)
      allow read: if isAuth();
      // Only super admins can create new orgs
      allow create: if isSuperAdmin();
      // Only org admin/owner or super admin can update
      allow update: if isOrgAdminOrOwner(orgId) || isSuperAdmin();
      // Deletion must be done via Cloud Function to ensure full cleanup
      allow delete: if false;

      // ── MEMBERS ─────────────────────────────────────────
      match /members/{memberId} {
        // User can read their own membership; admins/owners can read all
        allow read: if isAuth() &&
          (isOwner(memberId) || isOrgAdminOrOwner(orgId) || isSuperAdmin());

        // User can create their own PENDING TEACHER membership (join request)
        // OR create their own APPROVED OWNER membership when creating the org
        allow create: if isAuth() && isOwner(memberId) && (
          // Join request: must be pending teacher
          (request.resource.data.status == 'pending' &&
           request.resource.data.role == 'teacher') ||
          // Org creation: owner sets themselves as approved owner
          (request.resource.data.status == 'approved' &&
           request.resource.data.role == 'owner' &&
           request.resource.data.uid == request.auth.uid)
        );

        // Admin/Owner can update any member (approve/reject/role change)
        allow update: if isOrgAdminOrOwner(orgId) || isSuperAdmin();

        // Admin/Owner can delete members
        allow delete: if isOrgAdminOrOwner(orgId) || isSuperAdmin();
      }

      // ── ORG-SCOPED DATA (strict tenant isolation) ───────
      // Only APPROVED members can access org data
      match /schools/{schoolId} {
        allow read: if isApprovedOrgMember(orgId) || isSuperAdmin();
        // Admins and Super Admins can do anything
        allow write: if isOrgAdminOrOwner(orgId) || isSuperAdmin();
        // Teachers can update gallery-related fields but not location or name
        allow update: if isApprovedOrgMember(orgId) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['gallery', 'updatedAt', 'galleryVersion', 'name', 'createdBy']);
        // Teachers can create a school doc when it doesn't exist yet (e.g. first gallery upload)
        // Allowed fields mirror the update rule plus the minimum identity fields
        allow create: if isApprovedOrgMember(orgId) &&
          request.resource.data.keys().hasOnly(['gallery', 'updatedAt', 'galleryVersion', 'name', 'createdBy']);

        match /students/{studentId} {
          allow read: if isApprovedOrgMember(orgId) || isSuperAdmin();
          allow write: if isApprovedOrgMember(orgId) || isSuperAdmin();
        }
      }

      match /schedules/{scheduleId} {
        allow read: if isApprovedOrgMember(orgId) || isSuperAdmin();
        allow write: if isApprovedOrgMember(orgId) || isSuperAdmin();
      }

      match /lessons/{lessonId} {
        allow read: if isApprovedOrgMember(orgId) || isSuperAdmin();
        allow write: if isApprovedOrgMember(orgId) || isSuperAdmin();

        match /attendance/{studentId} {
          allow read: if isApprovedOrgMember(orgId) || isSuperAdmin();
          allow write: if isApprovedOrgMember(orgId) || isSuperAdmin();
        }
      }

      // ── ANNOUNCEMENTS ────────────────────────────────────
      // Any approved member can read; only admins/owners can write.
      match /announcements/{announcementId} {
        allow read: if isApprovedOrgMember(orgId) || isSuperAdmin();
        allow create, delete: if isOrgAdminOrOwner(orgId) || isSuperAdmin();
        allow update: if false; // announcements are immutable once posted
      }
    }

    // ── LEGACY TEACHER DATA (V1) ────────────────────────────
    match /teacherData/{teacherUid} {
      allow read: if isAuth() && (isOwner(teacherUid) || isSuperAdmin());
      allow write: if isAuth() && (isOwner(teacherUid) || isSuperAdmin());
    }
  }
}
