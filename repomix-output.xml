<file path="storage.rules">
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/galleries/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
