rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Legacy user-scoped gallery images
    match /users/{userId}/galleries/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Org-scoped gallery images
    // Any authenticated user can read; write requires auth (fine-grained via Firestore)
    match /orgs/{orgId}/galleries/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // User avatars
    match /userAvatars/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
