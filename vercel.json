{
    "version": 2,
    "installCommand": "npm install",
    "buildCommand": "npx expo export -p web && node scripts/fix-web-icons.js",
    "framework": null,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}